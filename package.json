{
	"name": "@markbattistella/docsify-autoheaders-docs",
	"version": "5.0.0",
	"description": "Documentation for docsify-autoHeaders",
	"main": "inhex.html",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/markbattistella/docsify-autoHeaders.git"
	},
	"author": "Mark Battistella",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/markbattistella/docsify-autoHeaders/issues"
	},
	"homepage": "https://markbattistella.github.io/docsify-charty-docs/",
	"keywords": [
		"auto numbering",
		"headings",
		"docsify",
		"plugin"
	],
	"scripts": {
		"launch": "docsify serve . -o",
        "update": "ncu -u && npm update && npm install",
        "babel": "npx babel dist/docsify-autoHeaders.js -o dist/docsify-autoHeaders.babel.js",
        "uglify": "uglifyjs dist/docsify-autoHeaders.babel.js --verbose -c -m -o dist/docsify-autoHeaders.min.js",
        "minify": "npm run babel && npm run uglify"
    },
    "devDependencies": {
        "@babel/cli": "^7.16.8",
        "@babel/core": "^7.16.7",
        "@babel/preset-env": "^7.16.8"
    },
    "babel": {
        "presets": [
            "@babel/env"
        ]
    }
}
